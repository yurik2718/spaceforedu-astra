---
import PublicLayout from "@/layouts/PublicLayout.astro";
import { EspanolPage } from "@/components/pages/Espanol";
import JsonLd from "@/components/common/JsonLd.astro";
import { getMessages } from "@/lib/i18n";
import { getSeo } from "@/lib/seo";
import { LOCALES, type Locale } from "@/lib/constants";
import { publicPages } from "@/lib/routes";
import { service, faqPage } from "@/lib/structured-data";

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as Locale;
const messages = getMessages(locale);
const seo = getSeo("espanol", locale);

const serviceLd = service({
  locale,
  name: seo.title,
  description: seo.description,
  page: publicPages.espanol,
  serviceType: "Spanish language course",
  audience: "International students and professionals learning Spanish in Spain or online",
});
const faqLd = faqPage(messages, "public.espanol", 5);
---

<PublicLayout
  title={seo.title}
  description={seo.description}
  locale={locale}
  page={publicPages.espanol}
>
  <JsonLd slot="structured-data" data={serviceLd} />
  {faqLd && <JsonLd slot="structured-data" data={faqLd} />}
  <EspanolPage client:idle locale={locale} messages={messages} />
</PublicLayout>
