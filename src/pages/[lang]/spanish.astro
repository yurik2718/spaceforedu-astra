---
import { getImage } from "astro:assets";
import PublicLayout from "@/layouts/PublicLayout.astro";
import { EspanolPage } from "@/components/pages/Espanol";
import JsonLd from "@/components/common/JsonLd.astro";
import { getMessages, makeT } from "@/lib/i18n";
import { getSeo } from "@/lib/seo";
import { LOCALES, type Locale } from "@/lib/constants";
import { publicPages } from "@/lib/routes";
import { service, faqPage, breadcrumbList } from "@/lib/structured-data";
import heroSrc from "@/assets/images/services/espanol/students-spanish-class-focused.webp";

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as Locale;
const messages = getMessages(locale);
const t = makeT(messages);
const seo = getSeo("espanol", locale);

const serviceLd = service({
  locale,
  name: seo.title,
  description: seo.description,
  page: publicPages.espanol,
  serviceType: "Spanish language course",
  audience: "International students and professionals learning Spanish in Spain or online",
});
const faqLd = faqPage(messages, "public.espanol", 5);
const breadcrumbLd = breadcrumbList(locale, t("nav.espanol"), publicPages.espanol);

const widths = [480, 768, 1024, 1280];
const heroAvif = await getImage({ src: heroSrc, format: "avif", width: 1280, widths, quality: 70 });
const heroWebp = await getImage({ src: heroSrc, format: "webp", width: 1280, widths, quality: 80 });
// Espanol shows hero on mobile too (full-width on small screens, ~40vw on desktop).
const heroSizes = "(min-width: 1024px) 40vw, 90vw";
---

<PublicLayout
  title={seo.title}
  description={seo.description}
  locale={locale}
  page={publicPages.espanol}
  heroImage={heroWebp.src}
  heroImageType="image/webp"
  heroImageSrcset={heroWebp.srcSet?.attribute}
  heroImageAvifSrcset={heroAvif.srcSet?.attribute}
  heroImageSizes={heroSizes}
  heroPreloadMedia="all"
>
  <JsonLd slot="structured-data" data={serviceLd} />
  <JsonLd slot="structured-data" data={breadcrumbLd} />
  {faqLd && <JsonLd slot="structured-data" data={faqLd} />}
  <EspanolPage
    client:idle
    locale={locale}
    messages={messages}
    heroMain={{
      src: heroWebp.src,
      srcSet: heroWebp.srcSet?.attribute,
      avifSrcSet: heroAvif.srcSet?.attribute,
      width: heroSrc.width,
      height: heroSrc.height,
    }}
  />
</PublicLayout>
