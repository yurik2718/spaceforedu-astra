---
import { getImage } from "astro:assets";
import PublicLayout from "@/layouts/PublicLayout.astro";
import { HomePage } from "@/components/pages/Home";
import JsonLd from "@/components/common/JsonLd.astro";
import { getMessages } from "@/lib/i18n";
import { getSeo } from "@/lib/seo";
import { LOCALES, type Locale } from "@/lib/constants";
import { website, serviceList } from "@/lib/structured-data";
import heroSrc from "@/assets/images/hero/hero-student-salamanca-docs.webp";

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as Locale;
const messages = getMessages(locale);
const seo = getSeo("home", locale);

// Generate AVIF for modern browsers and WebP as a fallback for Safari < 16
// and older Android Chrome that don't support AVIF.
// `width: 1280` makes the fallback .src URL the 1280-wide variant (not the original 1920),
// so older browsers without srcset get an appropriately sized image.
const widths = [480, 768, 1024, 1280];
const heroAvif = await getImage({ src: heroSrc, format: "avif", width: 1280, widths, quality: 70 });
const heroWebp = await getImage({ src: heroSrc, format: "webp", width: 1280, widths, quality: 80 });
const heroSizes = "(min-width: 1024px) 40vw, 50vw";
---

<PublicLayout
  title={seo.title}
  description={seo.description}
  locale={locale}
  page=""
  heroImage={heroWebp.src}
  heroImageType="image/webp"
  heroImageSrcset={heroWebp.srcSet?.attribute}
  heroImageAvifSrcset={heroAvif.srcSet?.attribute}
  heroImageSizes={heroSizes}
>
  <JsonLd slot="structured-data" data={website()} />
  <JsonLd slot="structured-data" data={serviceList(locale)} />
  <HomePage
    client:idle
    locale={locale}
    messages={messages}
    heroMain={{
      src: heroWebp.src,
      srcSet: heroWebp.srcSet?.attribute,
      avifSrcSet: heroAvif.srcSet?.attribute,
      width: heroSrc.width,
      height: heroSrc.height,
    }}
  />
</PublicLayout>
