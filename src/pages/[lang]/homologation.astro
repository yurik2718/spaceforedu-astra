---
import PublicLayout from "@/layouts/PublicLayout.astro";
import { HomologacionPage } from "@/components/pages/Homologacion";
import JsonLd from "@/components/common/JsonLd.astro";
import { getMessages } from "@/lib/i18n";
import { getSeo } from "@/lib/seo";
import { LOCALES, type Locale } from "@/lib/constants";
import { publicPages } from "@/lib/routes";
import { service, faqPage } from "@/lib/structured-data";

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as Locale;
const messages = getMessages(locale);
const seo = getSeo("homologacion", locale);

const serviceLd = service({
  locale,
  name: seo.title,
  description: seo.description,
  page: publicPages.homologacion,
  serviceType: "Degree homologation",
  audience: "International students and professionals with foreign degrees seeking official recognition in Spain",
});
const faqLd = faqPage(messages, "public.homologacion", 5);
---

<PublicLayout
  title={seo.title}
  description={seo.description}
  locale={locale}
  page={publicPages.homologacion}
>
  <JsonLd slot="structured-data" data={serviceLd} />
  {faqLd && <JsonLd slot="structured-data" data={faqLd} />}
  <HomologacionPage client:load locale={locale} messages={messages} />
</PublicLayout>
