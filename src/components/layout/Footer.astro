---
import { publicRoute, publicPages } from "@/lib/routes";
import { CONTACT_EMAIL, CONTACT_WHATSAPP } from "@/lib/constants";
import { formatPhone } from "@/lib/utils";
import { getMessages, makeT } from "@/lib/i18n";

interface Props {
  locale: string;
}

const { locale } = Astro.props;
const messages = getMessages(locale);
const t = makeT(messages);

const year = new Date().getFullYear();
---

<footer class="bg-white border-t border-[var(--hairline)]">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <div>
        <a href={publicRoute(publicPages.home, locale)} class="inline-flex items-center gap-2.5 mb-4">
          <img src="/favicon.svg" alt="" width="32" height="32" class="h-8 w-8 rounded-lg" />
          <span class="font-display text-[18px] font-bold tracking-[-0.02em] text-[var(--ink)]">
            Space for Edu
          </span>
        </a>
        <p class="text-sm text-[var(--mute)] leading-relaxed max-w-[340px] mb-4">
          {t("footer.tagline")}
        </p>
        <div class="flex flex-wrap gap-2">
          <a
            href={publicRoute(publicPages.home, "es")}
            class="inline-flex items-center gap-1.5 bg-[var(--surface-card)] rounded-full px-3 py-1.5 text-xs font-semibold text-[var(--ink)] hover:bg-[var(--secondary-bg)] transition-colors"
          >
            <img src="/images/flags/es.svg" alt="" width="18" height="13" class="w-[18px] h-[13px] rounded-[2px] object-cover" />
            Español
          </a>
          <a
            href={publicRoute(publicPages.home, "en")}
            class="inline-flex items-center gap-1.5 bg-[var(--surface-card)] rounded-full px-3 py-1.5 text-xs font-semibold text-[var(--ink)] hover:bg-[var(--secondary-bg)] transition-colors"
          >
            <img src="/images/flags/gb.svg" alt="" width="18" height="13" class="w-[18px] h-[13px] rounded-[2px] object-cover" />
            English
          </a>
          <a
            href={publicRoute(publicPages.home, "ru")}
            class="inline-flex items-center gap-1.5 bg-[var(--surface-card)] rounded-full px-3 py-1.5 text-xs font-semibold text-[var(--ink)] hover:bg-[var(--secondary-bg)] transition-colors"
          >
            <img src="/images/flags/ru.svg" alt="" width="18" height="13" class="w-[18px] h-[13px] rounded-[2px] object-cover" />
            Русский
          </a>
        </div>
      </div>

      <div>
        <h3 class="text-[13px] font-bold uppercase tracking-[0.08em] text-[var(--ink)] mb-4">
          {t("footer.services")}
        </h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href={publicRoute(publicPages.homologacion, locale)} class="text-[var(--mute)] hover:text-[var(--ink)] transition-colors">
              {t("nav.homologacion")}
            </a>
          </li>
          <li>
            <a href={publicRoute(publicPages.universidad, locale)} class="text-[var(--mute)] hover:text-[var(--ink)] transition-colors">
              {t("nav.universidad")}
            </a>
          </li>
          <li>
            <a href={publicRoute(publicPages.espanol, locale)} class="text-[var(--mute)] hover:text-[var(--ink)] transition-colors">
              {t("nav.espanol")}
            </a>
          </li>
          <li>
            <a href={publicRoute(publicPages.precios, locale)} class="text-[var(--mute)] hover:text-[var(--ink)] transition-colors">
              {t("nav.precios")}
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-[13px] font-bold uppercase tracking-[0.08em] text-[var(--ink)] mb-4">
          {t("footer.company")}
        </h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href={publicRoute(publicPages.privacyPolicy, locale)} class="text-[var(--mute)] hover:text-[var(--ink)] transition-colors">
              {t("footer.privacy")}
            </a>
          </li>
          <li>
            <a href={publicRoute(publicPages.legalNotice, locale)} class="text-[var(--mute)] hover:text-[var(--ink)] transition-colors">
              {t("footer.legal_notice")}
            </a>
          </li>
          <li>
            <a href={publicRoute(publicPages.cookies, locale)} class="text-[var(--mute)] hover:text-[var(--ink)] transition-colors">
              {t("footer.cookies")}
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-[13px] font-bold uppercase tracking-[0.08em] text-[var(--ink)] mb-4">
          {t("footer.contact")}
        </h3>
        <ul class="space-y-2 text-sm">
          {
            CONTACT_EMAIL && (
              <li>
                <a href={`mailto:${CONTACT_EMAIL}`} class="text-[var(--mute)] hover:text-[var(--ink)] transition-colors">
                  {CONTACT_EMAIL}
                </a>
              </li>
            )
          }
          {
            CONTACT_WHATSAPP && (
              <li>
                <a
                  href={`https://wa.me/${CONTACT_WHATSAPP}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={t("a11y.whatsapp_aria")}
                  class="text-[var(--mute)] hover:text-[var(--ink)] transition-colors"
                >
                  {formatPhone(CONTACT_WHATSAPP)}
                </a>
              </li>
            )
          }
          <li class="text-[var(--mute)]">{t("footer.address")}</li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-5 border-t border-[var(--hairline-soft)] flex flex-col sm:flex-row items-center justify-between gap-3 text-[13px] text-[var(--mute)]">
      <span>© {year} Space for Edu. {t("footer.rights")}</span>
      <div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-1">
        <a href={publicRoute(publicPages.privacyPolicy, locale)} class="hover:text-[var(--ink)] transition-colors">
          {t("footer.privacy")}
        </a>
        <a href={publicRoute(publicPages.legalNotice, locale)} class="hover:text-[var(--ink)] transition-colors">
          {t("footer.legal_notice")}
        </a>
        <a href={publicRoute(publicPages.cookies, locale)} class="hover:text-[var(--ink)] transition-colors">
          {t("footer.cookies")}
        </a>
      </div>
    </div>
  </div>
</footer>
