---
import { publicRoute, publicPages, whatsappLink } from "@/lib/routes";
import { CONTACT_WHATSAPP } from "@/lib/constants";
import { getMessages, makeT } from "@/lib/i18n";
import MobileNav from "@/components/layout/MobileNav.tsx";
import { LanguageSwitcher } from "@/components/common/LanguageSwitcher.tsx";

interface Props {
  locale: string;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const messages = getMessages(locale);
const t = makeT(messages);

const navLinks = [
  { key: "homologacion", href: publicRoute(publicPages.homologacion, locale) },
  { key: "universidad", href: publicRoute(publicPages.universidad, locale) },
  { key: "espanol", href: publicRoute(publicPages.espanol, locale) },
  { key: "precios", href: publicRoute(publicPages.precios, locale) },
];

const waHref = CONTACT_WHATSAPP ? whatsappLink(CONTACT_WHATSAPP) : "";
const homeHref = publicRoute(publicPages.home, locale);
---

<header class="sticky top-0 z-50 w-full border-b border-[var(--hairline-soft)] bg-white/96 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-7xl items-center gap-4 px-4 sm:px-6 lg:px-8">
    {locale === "es" && (
      <div
        aria-hidden="true"
        class="absolute inset-x-0 bottom-[-4px] h-1 flex pointer-events-none"
      >
        <span class="flex-[1] bg-[var(--primary)]"></span>
        <span class="flex-[2] bg-[#F1BF00]"></span>
        <span class="flex-[1] bg-[var(--primary)]"></span>
      </div>
    )}
    <a href={homeHref} class="flex items-center shrink-0">
      <span class="font-display text-[20px] font-bold tracking-[-0.02em] text-[var(--ink)]">
        Space for Edu
      </span>
    </a>

    <nav class="hidden lg:flex items-center gap-1 ml-3">
      {
        navLinks.map(({ key, href }) => {
          const isActive = currentPath.startsWith(href);
          const linkClass = [
            "px-3.5 py-2 text-sm font-semibold rounded-full transition-colors",
            isActive
              ? "bg-[var(--ink)] text-white"
              : "text-[var(--body-color)] hover:bg-[var(--surface-card)] hover:text-[var(--ink)]",
          ].join(" ");
          return (
            <a href={href} class={linkClass}>
              {t(`nav.${key}`)}
            </a>
          );
        })
      }
    </nav>

    <div class="ml-auto hidden lg:flex items-center gap-2">
      <LanguageSwitcher client:load locale={locale} currentPath={currentPath} />
      {
        waHref && (
          <a
            href={waHref}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={t("nav.start_aria")}
            class="inline-flex items-center justify-center h-9 px-4 rounded-2xl text-sm font-bold bg-[var(--primary)] text-white hover:bg-[var(--primary-pressed)] transition-colors duration-150"
          >
            {t("nav.start")}
          </a>
        )
      }
    </div>

    <div class="ml-auto flex lg:hidden items-center gap-2">
      <MobileNav
        client:load
        locale={locale}
        currentPath={currentPath}
        navLabels={{
          homologacion: t("nav.homologacion"),
          universidad: t("nav.universidad"),
          espanol: t("nav.espanol"),
          precios: t("nav.precios"),
        }}
        navHrefs={{
          homologacion: publicRoute(publicPages.homologacion, locale),
          universidad: publicRoute(publicPages.universidad, locale),
          espanol: publicRoute(publicPages.espanol, locale),
          precios: publicRoute(publicPages.precios, locale),
          home: homeHref,
        }}
        menuLabel={t("nav.menu")}
        closeLabel={t("nav.close")}
        ctaLabel={t("nav.start")}
        ctaAriaLabel={t("nav.start_aria")}
        waHref={waHref}
        whatsappPhone={CONTACT_WHATSAPP}
        whatsappFormatted=""
        phoneAriaLabel={t("a11y.phone_aria")}
      />
    </div>
  </div>
</header>
