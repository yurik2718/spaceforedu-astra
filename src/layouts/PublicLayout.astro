---
import "@/styles/global.css";
import ClientRouter from "astro/components/ClientRouter.astro";
import Navbar from "@/components/layout/Navbar.astro";
import Footer from "@/components/layout/Footer.astro";
import JsonLd from "@/components/common/JsonLd.astro";
import { StickyCtaBar } from "@/components/public/StickyCtaBar.tsx";
import CookieBanner from "@/components/common/CookieBanner.astro";
import GtmHead from "@/components/common/GtmHead.astro";
import GtmBody from "@/components/common/GtmBody.astro";
import { SITE_URL, LOCALES, DEFAULT_LOCALE, type Locale } from "@/lib/constants";
import { publicRoute } from "@/lib/routes";
import { getMessages, makeT } from "@/lib/i18n";
import { organization } from "@/lib/structured-data";
import interTightLatin from "@fontsource-variable/inter-tight/files/inter-tight-latin-wght-normal.woff2?url";
import interLatin from "@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url";

interface Props {
  title: string;
  description?: string;
  locale: string;
  /** Path portion (without locale) — "homologation", "university", "" for home. */
  page: string;
  ogImage?: string;
  /** Hide the sticky WhatsApp bubble + mobile CTA bar (for thank-you / privacy pages). */
  hideStickyCta?: boolean;
  /** LCP image — preloaded with high priority. Path under /public. Used only if heroImageSrcset not provided. */
  heroImage?: string;
  /** MIME type of heroImage (default image/webp). */
  heroImageType?: string;
  /** Responsive srcset string for the LCP image. When set, preload uses imagesrcset/imagesizes so the browser picks the right size. */
  heroImageSrcset?: string;
  /** Optional AVIF srcset preloaded alongside heroImageSrcset for browsers that support image/avif.
   *  Browsers that don't (Safari < 16, older Android Chrome) fall through to heroImageSrcset. */
  heroImageAvifSrcset?: string;
  /** sizes attribute paired with heroImageSrcset (e.g. "(min-width: 1024px) 40vw, 50vw"). */
  heroImageSizes?: string;
  /** Optional media query to scope the preload (e.g. desktop-only hero). */
  heroPreloadMedia?: string;
  /** Mark the page as non-indexable (404 etc.) — emits noindex and skips canonical/hreflang. */
  noindex?: boolean;
}

const {
  title,
  description = "",
  locale,
  page,
  ogImage: ogImageProp,
  hideStickyCta = false,
  heroImage,
  heroImageType = "image/webp",
  heroImageSrcset,
  heroImageAvifSrcset,
  heroImageSizes,
  heroPreloadMedia = "(min-width: 768px)",
  noindex = false,
} = Astro.props;
const currentPath = Astro.url.pathname;
const stickyMessages = getMessages(locale);
const t = makeT(stickyMessages);
const skipLabel = t("a11y.skip_to_content");

const canonicalUrl = SITE_URL + publicRoute(page, locale);
const alternates = LOCALES.map((l) => ({
  locale: l,
  url: SITE_URL + publicRoute(page, l),
}));
const defaultAlt = alternates.find((a) => a.locale === DEFAULT_LOCALE);
const xDefault = defaultAlt?.url ?? alternates[0].url;
// Per-page generated OG images for main content pages.
// Maps the `page` prop value (publicPages slug) to the SEO key used in the endpoint.
const PAGE_OG_KEY: Record<string, string> = {
  "": "home",
  homologation: "homologacion",
  university: "universidad",
  spanish: "espanol",
  pricing: "precios",
};
const ogImage =
  ogImageProp ??
  (PAGE_OG_KEY[page] != null ? `/og/${locale}/${PAGE_OG_KEY[page]}.png` : "/og.jpg");
const absoluteOgImage = ogImage.startsWith("http") ? ogImage : SITE_URL + ogImage;
const isGeneratedOg = !ogImageProp && PAGE_OG_KEY[page] != null;

// Canonical OG locale codes (Facebook spec requires xx_XX form).
const OG_LOCALE: Record<string, string> = {
  es: "es_ES",
  en: "en_US",
  ru: "ru_RU",
};
const ogLocale = OG_LOCALE[locale] ?? `${locale}_${locale.toUpperCase()}`;
const ogLocaleAlternates = LOCALES
  .filter((l) => l !== locale)
  .map((l) => OG_LOCALE[l] ?? `${l}_${l.toUpperCase()}`);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <ClientRouter />

    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <meta name="author" content="Space for Edu" />
    <meta name="publisher" content="Space for Edu" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {!noindex && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:image" content={absoluteOgImage} />
    {isGeneratedOg && <meta property="og:image:width" content="1200" />}
    {isGeneratedOg && <meta property="og:image:height" content="630" />}
    {isGeneratedOg && <meta property="og:image:type" content="image/png" />}
    <meta property="og:site_name" content="Space for Edu" />
    <meta property="og:locale" content={ogLocale} />
    {ogLocaleAlternates.map((l) => (
      <meta property="og:locale:alternate" content={l} />
    ))}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    <link
      rel="preload"
      as="font"
      href={interTightLatin}
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      as="font"
      href={interLatin}
      type="font/woff2"
      crossorigin="anonymous"
    />

    {heroImage && !noindex && (
      heroImageSrcset && heroImageSizes ? (
        <>
          {heroImageAvifSrcset && (
            <link
              rel="preload"
              as="image"
              imagesrcset={heroImageAvifSrcset}
              imagesizes={heroImageSizes}
              type="image/avif"
              fetchpriority="high"
              media={heroPreloadMedia}
            />
          )}
          <link
            rel="preload"
            as="image"
            imagesrcset={heroImageSrcset}
            imagesizes={heroImageSizes}
            type={heroImageType}
            fetchpriority="high"
            media={heroPreloadMedia}
          />
        </>
      ) : (
        <link
          rel="preload"
          as="image"
          href={heroImage}
          type={heroImageType}
          fetchpriority="high"
          media={heroPreloadMedia}
        />
      )
    )}

    {!noindex && (
      <>
        <link rel="canonical" href={canonicalUrl} />
        {alternates.map(({ locale: l, url }) => (
          <link rel="alternate" hreflang={l} href={url} />
        ))}
        <link rel="alternate" hreflang="x-default" href={xDefault} />
      </>
    )}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#E8453C" />

    {!noindex && <JsonLd data={organization()} />}
    <slot name="structured-data" />
    <GtmHead />
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <GtmBody />
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[60] focus:rounded-md focus:bg-foreground focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-background"
    >
      {skipLabel}
    </a>
    <div class={`min-h-screen flex flex-col ${hideStickyCta ? "" : "pb-[calc(72px+env(safe-area-inset-bottom))] lg:pb-0"}`}>
      <Navbar locale={locale} currentPath={currentPath} />
      <main id="main" class="flex-1 overflow-x-clip">
        <slot />
      </main>
      <Footer locale={locale} />
    </div>
    {!hideStickyCta && (
      <StickyCtaBar client:load locale={locale as Locale} messages={stickyMessages} />
    )}
    <CookieBanner locale={locale} />

    <script>
      import Lenis from "lenis";

      let lenis: Lenis | null = null;

      function initLenis() {
        lenis?.destroy();

        // Only enable on non-touch devices — mobile already has native momentum scroll.
        if (window.matchMedia("(hover: none)").matches) return;
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

        lenis = new Lenis({ duration: 1.15, easing: (t) => 1 - Math.pow(1 - t, 4) });

        function raf(time: number) {
          lenis!.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);
      }

      // astro:page-load fires on first load and after every View Transition.
      document.addEventListener("astro:page-load", initLenis);
    </script>
  </body>
</html>
