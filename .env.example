# Public site settings — exposed to client bundles. All vars must be prefixed PUBLIC_.

# WhatsApp phone, digits only (country code + number, no + or spaces).
PUBLIC_CONTACT_WHATSAPP=34600000000

# Contact email shown in the footer and on the thank-you page.
PUBLIC_CONTACT_EMAIL=hello@spaceforedu.com

# Absolute site URL (used for canonical links and hreflang alternates).
PUBLIC_SITE_URL=https://spaceforedu.com
